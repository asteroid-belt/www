---
import '../styles/global.css'
import { Header, Footer } from '../components/ui'
import { SEO } from 'astro-seo'

interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const {
  title = 'Asteroid Belt',
  description = 'AI-native development tools',
  ogImage = 'https://asteroidbelt.co/logo.png',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#131313" />
    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title: title,
          type: 'website',
          image: ogImage,
          url: 'https://asteroidbelt.co',
        },
      }}
      extend={{
        link: [{ rel: 'icon', href: 'https://asteroidbelt.co/favicon.ico' }],
        meta: [
          {
            name: 'twitter:image',
            content: ogImage,
          },
          { name: 'twitter:title', content: title },
          {
            name: 'twitter:description',
            content: description,
          },
        ],
      }}
    />
  </head>
  <body class="font-ibm-plex-sans min-h-screen bg-black text-center text-white lg:text-left">
    <Header />
    <main>
      <slot />
    </main>
    <Footer client:only="react" />
  </body>
</html>
